#Load clustered features and annotations
import pandas as pd
clustered_features = pd.read_csv("../results/baseline_annotation/clustered_features.csv")
ecmdb_annotations = pd.read_pickle("../results/ecmdb_annotations.pkl")

import requests
import re
from itertools import combinations
from tqdm import tqdm

#Get list of KEGG pathways for E. coli
url = "https://rest.kegg.jp/list/pathway/ec"
response = requests.get(url)

#Extract pathway IDs from KEGG response
pathways = [
    line.split()[0].replace("path:", "")
    for line in response.text.strip().split("\n")
]

print("Number of pathways:", len(pathways))



#Extract compounds from KEGG pathway entry
def extract_compounds_kegg(text):
    compounds = []
    capture = False

    for line in text.split("\n"):

        #Start capturing when COMPOUND section begins
        if line.startswith("COMPOUND"):
            capture = True

            #Extract first compound on same line
            match = re.search(r"(C\d{5})", line)
            if match:
                compounds.append(match.group(1))
            continue

        #Stop capturing when next section begins
        if capture:
            if re.match(r"^[A-Z_]+", line.strip()) and not line.startswith(" "):
                break

            #Extract KEGG compound IDs
            match = re.search(r"(C\d{5})", line)
            if match:
                compounds.append(match.group(1))

    return compounds



#Map pathways to compounds
pathway_to_compounds = {}

for pid in tqdm(pathways):

    #Download KEGG pathway entry
    url = f"https://rest.kegg.jp/get/{pid}"
    response = requests.get(url)

    #Extract compounds in pathway
    compounds = extract_compounds_kegg(response.text)

    #Store as set to remove duplicates
    pathway_to_compounds[pid] = set(compounds)



#Restrict to compounds present in annotation database
annotation_compounds = set()

for df in ecmdb_annotations.values():
    annotation_compounds.update(df["id"].dropna().unique())



#Build biochemical network (edges)
bio_edges = set()

for pid, compounds in pathway_to_compounds.items():

    #Keep only compounds that exist in annotation space
    compounds = compounds & annotation_compounds

    #Create all pairwise connections within each pathway
    for a, b in combinations(compounds, 2):
        bio_edges.add((a, b))



#Convert edge set to BIO dataframe
Bio = pd.DataFrame(list(bio_edges), columns=["0", "1"])

#Save for reuse
Bio.to_csv("../results/bio_connections.csv", index=False)



# deep copy so original annotations are preserved
import copy
biochemical_annotations = copy.deepcopy(ecmdb_annotations)

#Run BIO-aware Gibbs sampler
ipa.Gibbs_sampler_bio(clustered_features, biochemical_annotations, Bio, noits=2000, delta_bio=0.5)

#Run Gibbs_sampler_bio_add
biochemical_annotations_add = copy.deepcopy(biochemical_annotations)
ipa.Gibbs_sampler_bio_add(clustered_features, biochemical_annotations_add, Bio, noits=2000, delta_bio=0.5, delta_add=0.1)

#Output biochemical_annotations_add as pickle file
with open("../results/biochemical_annotations_add.pkl", "wb") as f:
    pickle.dump(biochemical_annotations_add, f)
